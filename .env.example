# This file lists optional environment variables.
# Uncomment only the sections you actually use.

## Supabase (only if using Supabase features)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

## Supabase Storage (only if using storage)
# SUPABASE_AUDIO_BUCKET=audio

## Google Vertex AI (Lyria) (only if using Lyria)
# VERTEX_PROJECT_ID=
# VERTEX_LOCATION=us-central1
# LYRIA_MODEL=lyria-002

## Gemini Live (Voice Control) (only if using live voice)
# GOOGLE_API_KEY=
# LIVE_VOICE_PORT=8000
# GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# NEXT_PUBLIC_LIVE_WS_URL=ws://localhost:8000

## Auth (only if needed)
# GOOGLE_APPLICATION_CREDENTIALS=
# GOOGLE_APPLICATION_CREDENTIALS_JSON=
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=
